{
  "name": "atp-exam-prep",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "validate:data": "tsx scripts/validateQuestionBank.ts",
    "verify": "npm run typecheck && npm run test && npm run lint && npm run validate:data && npm run build",
    "deploy:check": "cross-env GITHUB_ACTIONS=true GITHUB_REPOSITORY=dry-run/exam-prep-app npm run build && cross-env GITHUB_ACTIONS=true GITHUB_REPOSITORY=dry-run/exam-prep-app vite preview"
  },
  "dependencies": {
    "@fontsource/assistant": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "fuse.js": "^7.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
